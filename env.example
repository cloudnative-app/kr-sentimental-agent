# API Keys for LLM services
# Copy this file to .env and fill in your actual API keys

GEMINI_API_KEY=your_gemini_api_key_here
# OpenAI (또는 Azure OpenAI)
OPENAI_API_KEY=your_openai_or_azure_api_key_here
# Azure OpenAI 사용 시
OPENAI_AZURE_ENDPOINT=https://aoai-sentiment.openai.azure.com/
# Azure 배포 이름 (Azure OpenAI Studio > Deployments에서 확인 후 입력)
OPENAI_AZURE_DEPLOYMENT=gpt-4o-mini
ANTHROPIC_API_KEY=your_anthropic_api_key_here
